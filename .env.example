# Copia di riferimento per il primo avvio.
# `make setup` parte da questi default quando `.env` non esiste.

# Applicazione e sicurezza
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=
APP_SECRET_KEY=
APP_BIND_HOST=127.0.0.1
APP_PORT=8000
APP_SESSION_COOKIE_SECURE=false
APP_PROFILE_ENCRYPTION_KEY=

# Camera e accesso RTSP/ONVIF
TAPO_CAMERA_NAME="Camera principale"
TAPO_WIFI_SSID=
TAPO_HOST=192.168.1.50
TAPO_RTSP_PORT=554
TAPO_STREAM_PATH=stream1
TAPO_USERNAME=
TAPO_PASSWORD=
TAPO_ONVIF_PORT=2020
TAPO_ONVIF_USERNAME=
TAPO_ONVIF_PASSWORD=
TAPO_CAMERA_ACCOUNT_USER=
TAPO_CAMERA_ACCOUNT_PASSWORD=
TAPO_MOVE_SPEED=0.6
TAPO_MOVE_TIMEOUT=0.35

# Motion detection
MOTION_ENABLED=true
MOTION_MIN_AREA=1400
MOTION_THRESHOLD=24
MOTION_BLUR_SIZE=21
MOTION_COOLDOWN=3
MOTION_FRAME_INTERVAL=0.25
MOTION_CAPTURE_INTERVAL=0.18
MOTION_MAX_AREA_RATIO=0.45
MOTION_WARMUP_FRAMES=12
MOTION_TRIGGER_FRAMES=2
MOTION_CLEAR_FRAMES=8
MOTION_BACKGROUND_ALPHA=0.03
MOTION_SAVE_FRAMES=true
MOTION_SAVE_DIR=captures/motion
MOTION_EVENT_GAP=4.0
MOTION_EVENT_MAX_DURATION=45.0

# Stream tuning avanzato
RTSP_OPEN_TIMEOUT_SEC=8.0
RTSP_RECONNECT_BACKOFF_MAX_SEC=15.0
STREAM_SNAPSHOT_INTERVAL_ONLINE_MS=700
STREAM_SNAPSHOT_INTERVAL_OFFLINE_MS=2500
RTSP_BACKLOG_SKIP_FRAMES=1
STREAM_JPEG_QUALITY=85
STREAM_MAX_WIDTH=0
