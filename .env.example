# Copia di riferimento per il primo avvio.
# `make setup` parte da questi default quando `.env` non esiste.
#
# Mini PC Windows: usa il wizard guidato
#   .\install-windows.bat
#   .\blackframe.ps1 install-windows
# oppure copia il template già ottimizzato:
#   copy .env.windows-minipc.example .env
# Poi completa credenziali e segreti (o rilancia il wizard con -ForceConfig).

# Applicazione e sicurezza
APP_ADMIN_USERNAME=admin
# Password admin: usa APP_ADMIN_PASSWORD_HASH in produzione (nessun segreto in chiaro).
# Genera l'hash con: make hash-password
APP_ADMIN_PASSWORD=
APP_ADMIN_PASSWORD_HASH=
APP_SECRET_KEY=
APP_BIND_HOST=127.0.0.1
APP_PORT=8000
APP_SESSION_COOKIE_SECURE=false
# Scadenza assoluta della sessione admin (ore): oltre questo limite serve ri-login.
APP_SESSION_LIFETIME_HOURS=12
APP_PROFILE_ENCRYPTION_KEY=
# Fidati di X-Forwarded-For SOLO se davanti c'è un reverse proxy fidato che
# riscrive l'header. Lasciare false se l'app è raggiungibile direttamente:
# altrimenti il rate-limit anti brute-force del login è aggirabile.
APP_TRUST_PROXY=false
# Permette al pulsante "Apri cartella clip" di lanciare il file manager sul server.
# Disabilitato di default: abilitalo (true) SOLO su un'installazione desktop locale.
APP_ENABLE_OPEN_FOLDER=false
# Numero massimo di stream video MJPEG concorrenti. Ogni stream occupa un thread
# in lettura continua: il limite evita che troppe sessioni saturino la CPU.
APP_MAX_MJPEG_STREAMS=8
# Thread HTTP: 4 consigliato su CPU/RAM limitate. Gli stream MJPEG occupano
# thread a lungo; non usare più worker process (duplicherebbero camera e detector).
APP_GUNICORN_THREADS=8
APP_WAITRESS_THREADS=8

# Camera e accesso RTSP/ONVIF
TAPO_CAMERA_NAME="Camera principale"
TAPO_WIFI_SSID=
TAPO_HOST=192.168.1.50
TAPO_RTSP_PORT=554
# stream2 = sottostream SD (consigliato su mini PC Windows per meno CPU/falsi positivi)
TAPO_STREAM_PATH=stream1
TAPO_USERNAME=
TAPO_PASSWORD=
TAPO_ONVIF_PORT=2020
TAPO_ONVIF_USERNAME=
TAPO_ONVIF_PASSWORD=
TAPO_CAMERA_ACCOUNT_USER=
TAPO_CAMERA_ACCOUNT_PASSWORD=
TAPO_MOVE_SPEED=0.6
TAPO_MOVE_TIMEOUT=0.35

# Motion detection (modello MOG2: sottrazione background adattiva con esclusione ombre)
MOTION_ENABLED=true
# MOTION_MIN_AREA: area minima del blob IN PIXEL sul frame ridotto a MOTION_SCALE_WIDTH.
MOTION_MIN_AREA=600
# MOTION_THRESHOLD: sensibilità MOG2 (varThreshold). Più alto = meno sensibile/meno falsi positivi.
MOTION_THRESHOLD=35
MOTION_BLUR_SIZE=5
MOTION_COOLDOWN=3
MOTION_FRAME_INTERVAL=0.25
MOTION_CAPTURE_INTERVAL=0.18
MOTION_MAX_AREA_RATIO=0.45
MOTION_WARMUP_FRAMES=12
MOTION_TRIGGER_FRAMES=3
MOTION_CLEAR_FRAMES=8
MOTION_SAVE_FRAMES=true
MOTION_SAVE_DIR=captures/motion
MOTION_EVENT_GAP=4.0
MOTION_EVENT_MAX_DURATION=45.0
# Parametri MOG2 / denoising
MOTION_MOG2_HISTORY=500
MOTION_SCALE_WIDTH=480
MOTION_MORPH_KERNEL=3
MOTION_MORPH_DILATE_ITER=2
MOTION_GLOBAL_CHANGE_RATIO=0.5
MOTION_LEARNING_RATE=-1
MOTION_LEARNING_RATE_ACTIVE=0.0005
# MOTION_BACKGROUND_ALPHA è deprecato (sostituito da MOG2), ignorato se presente.

# Retention / pulizia automatica eventi (0 = limite disattivato)
MOTION_RETENTION_DAYS=14
MOTION_RETENTION_MAX_MB=5000
MOTION_RETENTION_INTERVAL_SEC=3600

# Registrazione video clip MP4 per evento (codec H.264, riproducibile da browser)
# Su Windows serve ffmpeg in PATH: winget install Gyan.FFmpeg
# RECORD_MAX_WIDTH: larghezza massima del video registrato in pixel (0 = risoluzione piena).
# Riduce dimensione file e tempi di invio Telegram. 1280 ≈ 720p.
RECORD_ENABLED=false
RECORD_FPS=10
RECORD_PREROLL_SEC=2.0
RECORD_MAX_DURATION_SEC=60
# Secondi di clip dopo la fine del movimento rilevato (coda dell'evento).
RECORD_POSTROLL_SEC=3.0
RECORD_MAX_WIDTH=1280

# Registrazione continua a ciclo (sovrascrittura automatica dei segmenti più vecchi)
# CONTINUOUS_RECORD_RETAIN_HOURS: durata totale da conservare (es. 3, 12, 24)
# CONTINUOUS_RECORD_SEGMENT_MIN: durata di ogni segmento MP4 in minuti
CONTINUOUS_RECORD_ENABLED=false
CONTINUOUS_RECORD_SEGMENT_MIN=10
CONTINUOUS_RECORD_RETAIN_HOURS=3
CONTINUOUS_RECORD_DIR=captures/continuous

# Automazione smart home (Tuya LAN)
# AUTOMATION_ENABLED: abilita il layer di automazione (default false = inerte).
# AUTOMATION_RULES_PATH: percorso al file YAML delle regole (default config/automation/rules.yaml).
# AUTOMATION_DEVICES_PATH: percorso al registry device cifrato (default data/tuya_devices.json).
# TUYA_SCAN_TIMEOUT_SEC: durata massima dello scan LAN dal wizard UI (default 10s).
AUTOMATION_ENABLED=false
AUTOMATION_RULES_PATH=config/automation/rules.yaml
AUTOMATION_DEVICES_PATH=data/tuya_devices.json
TUYA_SCAN_TIMEOUT_SEC=10
# Backpressure: massimo azioni in attesa; oltre il limite le nuove vengono scartate.
AUTOMATION_QUEUE_MAX=64

# Layer agentico (comandi in linguaggio naturale via Ollama locale)
# AGENT_ENABLED: abilita l'interpretazione NLU (default false = inerte, nessuna
# chiamata di rete). Richiede un'istanza Ollama raggiungibile con il modello scaricato
# (es. `ollama pull qwen2.5:0.5b`). Su hardware limitato preferire modelli ~0.5-1B.
# AGENT_OLLAMA_URL: endpoint HTTP di Ollama (default locale).
# AGENT_OLLAMA_MODEL: nome modello Ollama usato per l'intent-matching.
# AGENT_TIMEOUT_SEC: timeout chiamata Ollama; oltre questo l'agente risponde "non disponibile".
# AGENT_MAX_INPUT_CHARS: tetto lunghezza messaggio utente (difesa da prompt enormi su CPU limitata).
# AGENT_PENDING_TTL_SEC: quanto resta valida una proposta in attesa di conferma.
# AGENT_OLLAMA_KEEP_ALIVE: quanto Ollama tiene il modello caricato in RAM tra
#   una richiesta e l'altra (formato Ollama, es. "30m", "-1" per sempre).
#   Senza impostarlo vale il default di Ollama (5 minuti): su hardware limitato
#   ogni richiesta dopo un periodo di inattività ricarica il modello da disco,
#   con latenza che può superare AGENT_TIMEOUT_SEC.
# AGENT_FASTPATH: risolve le frasi frequenti ("stato", "accendi la lampada",
#   "gira a destra") con regole deterministiche locali, senza chiamare l'LLM:
#   latenza ~zero e nessun errore di interpretazione sui casi coperti.
# AGENT_SCHEMA_FORMAT: vincola la generazione del modello a uno schema JSON con
#   l'elenco esatto dei comandi (structured outputs, richiede Ollama >= 0.5;
#   con versioni piu' vecchie ripiega da solo su JSON generico).
# AGENT_PROMPT_EXAMPLES: aggiunge esempi few-shot come turni di chat prima del
#   messaggio reale (piu' precisione con modelli piccoli, un po' piu' prefill).
# AGENT_OLLAMA_NUM_CTX / AGENT_OLLAMA_NUM_PREDICT: dimensione contesto e tetto
#   token generati; valori bassi = meno RAM e meno latenza su CPU. Aumentare
#   NUM_CTX se si aggiungono molti comandi/dispositivi (il benchmark
#   scripts/benchmark_agent.py stampa la dimensione del prompt come guardia).
# AGENT_OLLAMA_TEMPERATURE: 0 = deterministico (consigliato per l'intent).
# AGENT_CONTEXT_TTL_SEC: memoria dell'ultimo turno per i follow-up
#   ("accendi la lampada" -> "ora spegnila"); 0 = disattiva.
# AGENT_NATURAL_ANSWERS: per le domande sui comandi di lettura ("le luci sono
#   accese?") una seconda chiamata LLM compone una risposta in italiano dai
#   dati del comando; se fallisce si mostra l'output grezzo.
# AGENT_ANSWER_MAX_RESULT_CHARS: tetto dati passati alla risposta naturale.
# AGENT_TRANSCRIPT_MAX: quanti messaggi della chat web /agente conservare su
#   disco (data/agent_transcript.json, ruotato oltre il tetto).
# AGENT_WARMUP: precarica il modello in RAM in background all'avvio/toggle,
#   cosi' il primo messaggio non paga il caricamento da disco.
AGENT_ENABLED=false
AGENT_OLLAMA_URL=http://127.0.0.1:11434
AGENT_OLLAMA_MODEL=qwen2.5:0.5b
AGENT_TIMEOUT_SEC=8
AGENT_MAX_INPUT_CHARS=300
AGENT_PENDING_TTL_SEC=120
AGENT_OLLAMA_KEEP_ALIVE=30m
AGENT_RESIDENCY_MODE=auto
AGENT_PRELOAD_ON_UI_OPEN=true
AGENT_RESIDENT_MIN_FREE_RAM_MB=2048
AGENT_MODEL_ESTIMATED_RAM_MB=1536
AGENT_FASTPATH=true
AGENT_SCHEMA_FORMAT=true
AGENT_PROMPT_EXAMPLES=true
AGENT_OLLAMA_NUM_CTX=1536
AGENT_OLLAMA_NUM_PREDICT=80
AGENT_OLLAMA_TEMPERATURE=0
AGENT_CONTEXT_TTL_SEC=600
AGENT_NATURAL_ANSWERS=true
AGENT_ANSWER_MAX_RESULT_CHARS=700
AGENT_TRANSCRIPT_MAX=200
AGENT_WARMUP=true
# Gate fail-closed prima dell'LLM + cache LRU bounded delle interpretazioni riuscite.
AGENT_DOMAIN_GATE=true
AGENT_CACHE=true
CAPABILITY_STATE_TTL_SEC=15
# Sicurezza SSRF: remoto vietato di default; abilitare solo per endpoint fidato.
AGENT_ALLOW_REMOTE_OLLAMA=false

# Notifiche Telegram (avviso con foto o clip video alla rilevazione)
# NOTIFY_ON_CLASSES: lista classi separate da virgola (es. persona). Vuoto = tutti gli eventi.
# Il filtro per classe richiede CLASSIFICATION_ENABLED=true.
# NOTIFY_PREFER_VIDEO: se true e RECORD_ENABLED=true, invia la clip MP4 invece della foto.
NOTIFY_TELEGRAM_ENABLED=false
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_ON_CLASSES=
NOTIFY_MIN_INTERVAL_SEC=8
NOTIFY_PREFER_VIDEO=true
# Oltre questa dimensione la clip viene sostituita dalla foto di copertina su Telegram.
NOTIFY_TELEGRAM_MAX_VIDEO_MB=20
# Tentativi di invio prima di scartare una notifica. Un invio fallito (timeout/blip
# di rete) viene ri-accodato con backoff esponenziale invece di andare perso.
NOTIFY_MAX_ATTEMPTS=4
# Limite coda persistente; a saturazione resta priorità agli eventi recenti.
NOTIFY_QUEUE_MAX=64

# Comandi Telegram remoti (usa stesso bot/token delle notifiche)
# Default sicuro: disabilitati. Se TELEGRAM_COMMANDS_ALLOWED_CHAT_IDS è vuoto,
# viene usato NOTIFY_TELEGRAM_CHAT_ID come unica chat autorizzata.
TELEGRAM_COMMANDS_ENABLED=false
TELEGRAM_COMMANDS_ALLOWED_CHAT_IDS=
TELEGRAM_COMMANDS_RATE_LIMIT_PER_MIN=20
TELEGRAM_COMMANDS_POLL_TIMEOUT_SEC=25
TELEGRAM_COMMANDS_SET_MENU=true
TELEGRAM_CLIP_MAX_CONCURRENT=1
# Allowlist ospiti: codice segreto per autorizzare nuovi utenti via /start <codice>
# o link https://t.me/<bot>?start=<codice>. Vuoto = inviti disabilitati.
# Gli ospiti autorizzati sono salvati in TELEGRAM_GUESTS_FILE (default: data/telegram_guests.json).
# Comandi admin: /invite (mostra link), /guests (lista), /revoke <chat_id> (rimuovi).
TELEGRAM_INVITE_CODE=
TELEGRAM_GUESTS_FILE=

# Classificazione persona/pet
# NOTA: nessun modello è incluso nel repo. Con CLASSIFICATION_ENABLED=true ma senza
# i file modello qui sotto, ogni evento resta "unknown" e l'app logga un warning
# all'avvio. Scarica il modello con `make fetch-model` prima di abilitare.
#
# Backend consigliato: detection (MobileNet-SSD v2 COCO via OpenCV DNN, nessuna
# dipendenza extra). Riconosce direttamente person/cat/dog, gira una volta per
# evento e localizza il soggetto: robusto anche su hardware modesto. CLASSIFICATION_
# MIN_CONFIDENCE è anche la soglia di score minimo delle detection.
CLASSIFICATION_ENABLED=false
CLASSIFICATION_BACKEND=detection
CLASSIFICATION_MIN_CONFIDENCE=0.55
CLASSIFICATION_SAMPLE_POLICY=event_cover
# Scansione clip a chiusura evento (il burst CPU piu' pesante su mini PC):
# CLASSIFICATION_CLIP_MAX_FRAMES: tetto di frame analizzati per clip (1 su 2,
#   il resto viene saltato senza decodifica completa).
# CLASSIFICATION_EARLY_EXIT_CONF: trovato un soggetto con confidenza >= soglia,
#   la scansione si ferma subito.
CLASSIFICATION_CLIP_MAX_FRAMES=24
CLASSIFICATION_EARLY_EXIT_CONF=0.85

# Categorie da notificare, attivabili in modo indipendente. Se rilevi una persona
# ma CLASSIFICATION_DETECT_PERSON=false (o un animale con DETECT_PET=false) l'evento
# viene registrato ma NON genera notifica. Con entrambe false, nessun evento
# classificato viene notificato. Gestibili anche da Telegram (/detect_person_on...).
CLASSIFICATION_DETECT_PERSON=true
CLASSIFICATION_DETECT_PET=true

# Backend: detection (MobileNet-SSD v2 COCO). File scaricati da `make fetch-model`.
CLASSIFICATION_DETECTION_MODEL_PATH=models/ssd_mobilenet_v2_coco.pb
CLASSIFICATION_DETECTION_CONFIG_PATH=models/ssd_mobilenet_v2_coco.pbtxt
CLASSIFICATION_DETECTION_INPUT_SIZE=300
# Ritaglia il frame sulla bbox di movimento prima della detection (più preciso sui
# soggetti piccoli). CROP_PADDING è il margine extra attorno alla bbox (frazione).
CLASSIFICATION_CROP_TO_MOTION=true
CLASSIFICATION_CROP_PADDING=0.2
# Con backend detection: se person e pet sono entrambi visibili, preferisci il pet
# quando la confidenza persona non supera il pet di almeno questo margine (0.0–1.0).
CLASSIFICATION_PET_PRIORITY_MARGIN=0.12

# Backend: local (modello ONNX a 2 classi, whole-frame — richiede un modello custom)
CLASSIFICATION_LOCAL_MODEL_PATH=models/person_pet.onnx
CLASSIFICATION_LOCAL_LABELS_PATH=models/person_pet_labels.txt

# Backend: teachable_machine (modello ONNX esportato da Google Teachable Machine)
CLASSIFICATION_TM_MODEL_PATH=models/teachable_machine.onnx
CLASSIFICATION_TM_LABELS_PATH=models/teachable_machine_labels.txt

# Backend: cloud (endpoint HTTP REST che riceve JPEG e ritorna {"label": "...", "confidence": 0.0})
CLASSIFICATION_CLOUD_ENDPOINT=
CLASSIFICATION_CLOUD_API_KEY=

# Stream tuning avanzato
RTSP_OPEN_TIMEOUT_SEC=8.0
RTSP_RECONNECT_BACKOFF_MAX_SEC=15.0
STREAM_SNAPSHOT_INTERVAL_ONLINE_MS=700
STREAM_SNAPSHOT_INTERVAL_OFFLINE_MS=2500
RTSP_BACKLOG_SKIP_FRAMES=1
STREAM_JPEG_QUALITY=85
STREAM_MAX_WIDTH=0
# Override cadenza encoding JPEG; 0 usa min(snapshot interval, 1/RECORD_FPS).
STREAM_ENCODE_INTERVAL_MS=0
# Limita parallelismo interno OpenCV; 1 evita oversubscription su mini-PC.
OPENCV_NUM_THREADS=

# Profili prestazioni dichiarativi (Eco/Bilanciato/Prestazioni).
# I path sono interni: non vengono accettati dalla UI/API come input arbitrario.
PERFORMANCE_PROFILE_CATALOG_PATH=config/performance_profiles.yaml
PERFORMANCE_PROFILE_STATE_PATH=data/performance_profile.json
