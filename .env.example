TAPO_USERNAME=il_tuo_username
TAPO_PASSWORD=la_tua_password
# Nota: username/password restano sensibili e non vengono esposti alla UI runtime.
TAPO_HOST=192.168.1.50
TAPO_RTSP_PORT=554
TAPO_STREAM_PATH=stream1
TAPO_ONVIF_PORT=2020
# Opzionale: se ONVIF usa credenziali diverse da RTSP, imposta queste.
TAPO_ONVIF_USERNAME=
TAPO_ONVIF_PASSWORD=
TAPO_MOVE_SPEED=0.6
TAPO_MOVE_TIMEOUT=0.35
MOTION_ENABLED=true
MOTION_MIN_AREA=2500
MOTION_THRESHOLD=35
MOTION_BLUR_SIZE=31
MOTION_COOLDOWN=5
MOTION_FRAME_INTERVAL=0.4
MOTION_WARMUP_FRAMES=12
MOTION_TRIGGER_FRAMES=3
MOTION_CLEAR_FRAMES=6
MOTION_BACKGROUND_ALPHA=0.08
MOTION_SAVE_FRAMES=true
MOTION_SAVE_DIR=captures/motion
MOTION_EVENT_GAP=3.0
