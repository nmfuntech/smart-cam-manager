# Copia di riferimento per il primo avvio.
# `make setup` parte da questi default quando `.env` non esiste.

# Applicazione e sicurezza
APP_ADMIN_USERNAME=admin
# Password admin: usa APP_ADMIN_PASSWORD_HASH in produzione (nessun segreto in chiaro).
# Genera l'hash con: make hash-password
APP_ADMIN_PASSWORD=
APP_ADMIN_PASSWORD_HASH=
APP_SECRET_KEY=
APP_BIND_HOST=127.0.0.1
APP_PORT=8000
APP_SESSION_COOKIE_SECURE=false
APP_PROFILE_ENCRYPTION_KEY=

# Camera e accesso RTSP/ONVIF
TAPO_CAMERA_NAME="Camera principale"
TAPO_WIFI_SSID=
TAPO_HOST=192.168.1.50
TAPO_RTSP_PORT=554
TAPO_STREAM_PATH=stream1
TAPO_USERNAME=
TAPO_PASSWORD=
TAPO_ONVIF_PORT=2020
TAPO_ONVIF_USERNAME=
TAPO_ONVIF_PASSWORD=
TAPO_CAMERA_ACCOUNT_USER=
TAPO_CAMERA_ACCOUNT_PASSWORD=
TAPO_MOVE_SPEED=0.6
TAPO_MOVE_TIMEOUT=0.35

# Motion detection (modello MOG2: sottrazione background adattiva con esclusione ombre)
MOTION_ENABLED=true
# MOTION_MIN_AREA: area minima del blob IN PIXEL sul frame ridotto a MOTION_SCALE_WIDTH.
MOTION_MIN_AREA=600
# MOTION_THRESHOLD: sensibilità MOG2 (varThreshold). Più alto = meno sensibile/meno falsi positivi.
MOTION_THRESHOLD=35
MOTION_BLUR_SIZE=5
MOTION_COOLDOWN=3
MOTION_FRAME_INTERVAL=0.25
MOTION_CAPTURE_INTERVAL=0.18
MOTION_MAX_AREA_RATIO=0.45
MOTION_WARMUP_FRAMES=12
MOTION_TRIGGER_FRAMES=3
MOTION_CLEAR_FRAMES=8
MOTION_SAVE_FRAMES=true
MOTION_SAVE_DIR=captures/motion
MOTION_EVENT_GAP=4.0
MOTION_EVENT_MAX_DURATION=45.0
# Parametri MOG2 / denoising
MOTION_MOG2_HISTORY=500
MOTION_SCALE_WIDTH=480
MOTION_MORPH_KERNEL=3
MOTION_MORPH_DILATE_ITER=2
MOTION_GLOBAL_CHANGE_RATIO=0.5
MOTION_LEARNING_RATE=-1
MOTION_LEARNING_RATE_ACTIVE=0.0005
# MOTION_BACKGROUND_ALPHA è deprecato (sostituito da MOG2), ignorato se presente.

# Retention / pulizia automatica eventi (0 = limite disattivato)
MOTION_RETENTION_DAYS=14
MOTION_RETENTION_MAX_MB=5000
MOTION_RETENTION_INTERVAL_SEC=3600

# Registrazione video clip MP4 per evento (codec H.264, riproducibile da browser)
# RECORD_MAX_WIDTH: larghezza massima del video registrato in pixel (0 = risoluzione piena).
# Riduce dimensione file e tempi di invio Telegram. 1280 ≈ 720p.
RECORD_ENABLED=false
RECORD_FPS=10
RECORD_PREROLL_SEC=2.0
RECORD_MAX_DURATION_SEC=60
RECORD_MAX_WIDTH=1280

# Registrazione continua a ciclo (sovrascrittura automatica dei segmenti più vecchi)
# CONTINUOUS_RECORD_RETAIN_HOURS: durata totale da conservare (es. 3, 12, 24)
# CONTINUOUS_RECORD_SEGMENT_MIN: durata di ogni segmento MP4 in minuti
CONTINUOUS_RECORD_ENABLED=false
CONTINUOUS_RECORD_SEGMENT_MIN=10
CONTINUOUS_RECORD_RETAIN_HOURS=3
CONTINUOUS_RECORD_DIR=captures/continuous

# Notifiche Telegram (avviso con foto o clip video alla rilevazione)
# NOTIFY_ON_CLASSES: lista classi separate da virgola (es. persona). Vuoto = tutti gli eventi.
# Il filtro per classe richiede CLASSIFICATION_ENABLED=true.
# NOTIFY_PREFER_VIDEO: se true e RECORD_ENABLED=true, invia la clip MP4 invece della foto.
NOTIFY_TELEGRAM_ENABLED=false
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_ON_CLASSES=
NOTIFY_MIN_INTERVAL_SEC=30
NOTIFY_PREFER_VIDEO=true

# Comandi Telegram remoti (usa stesso bot/token delle notifiche)
# Default sicuro: disabilitati. Se TELEGRAM_COMMANDS_ALLOWED_CHAT_IDS è vuoto,
# viene usato NOTIFY_TELEGRAM_CHAT_ID come unica chat autorizzata.
TELEGRAM_COMMANDS_ENABLED=false
TELEGRAM_COMMANDS_ALLOWED_CHAT_IDS=
TELEGRAM_COMMANDS_RATE_LIMIT_PER_MIN=20
TELEGRAM_COMMANDS_POLL_TIMEOUT_SEC=25
TELEGRAM_COMMANDS_SET_MENU=true

# Classificazione persona/pet
CLASSIFICATION_ENABLED=false
CLASSIFICATION_BACKEND=local
CLASSIFICATION_MIN_CONFIDENCE=0.55
CLASSIFICATION_SAMPLE_POLICY=event_cover
CLASSIFICATION_LOCAL_MODEL_PATH=models/person_pet.onnx
CLASSIFICATION_LOCAL_LABELS_PATH=models/person_pet_labels.txt

# Backend: teachable_machine (modello ONNX esportato da Google Teachable Machine)
CLASSIFICATION_TM_MODEL_PATH=models/teachable_machine.onnx
CLASSIFICATION_TM_LABELS_PATH=models/teachable_machine_labels.txt

# Backend: cloud (endpoint HTTP REST che riceve JPEG e ritorna {"label": "...", "confidence": 0.0})
CLASSIFICATION_CLOUD_ENDPOINT=
CLASSIFICATION_CLOUD_API_KEY=

# Stream tuning avanzato
RTSP_OPEN_TIMEOUT_SEC=8.0
RTSP_RECONNECT_BACKOFF_MAX_SEC=15.0
STREAM_SNAPSHOT_INTERVAL_ONLINE_MS=700
STREAM_SNAPSHOT_INTERVAL_OFFLINE_MS=2500
RTSP_BACKLOG_SKIP_FRAMES=1
STREAM_JPEG_QUALITY=85
STREAM_MAX_WIDTH=0
